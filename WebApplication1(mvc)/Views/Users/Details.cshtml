@model Users

<div class="container mt-5">

    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg border-0 rounded-3">

                <!-- Header -->
                <div class="card-header bg-dark text-white text-center py-3">
                    <h3 class="mb-0">User Details</h3>
                </div>

                <!-- Body -->
                <div class="card-body p-4">

                    <div class="mb-3">
                        <h5 class="fw-bold text-dark">Name</h5>
                        <p class="text-muted fs-5">@Model.Name</p>
                    </div>

                    <div class="mb-3">
                        <h5 class="fw-bold text-dark">Email</h5>
                        <p class="text-muted fs-5">@Model.Email</p>
                    </div>

                    <div class="mb-3">
                        <h5 class="fw-bold text-dark">Age</h5>
                        <p class="text-muted fs-5">@Model.Age</p>
                    </div>

                    <div class="mb-3">
                        <h5 class="fw-bold text-dark">Score</h5>
                        <p class="text-muted fs-5">@Model.Score</p>
                    </div>

                </div>

                <!-- Footer Buttons -->
                <div class="card-footer bg-transparent border-0 text-center">

                    <a href="/Users/Edit/@Model.Id" class="btn btn-outline-dark px-4 me-2">
                        Edit
                    </a>

                    <a href="/Users/Delete/@Model.Id" class="btn btn-outline-danger px-4 me-2">
                        Delete
                    </a>

                    <a href="/Users" class="btn btn-secondary px-4">
                        Back
                    </a>

                </div>
            </div>

        </div>
    </div>
</div>