@model List<Users>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">All Users</h2>

        <a href="/Users/Create" class="btn btn-dark">
            + Add New User
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center fs-5">
            🚫 No users found
        </div>
    }
    else
    {
        <div class="row g-4">

            @foreach (var user in Model)
            {
                <div class="col-md-4">
                    <div class="card shadow-sm border-0 rounded-3 h-100">

                        <div class="card-body">
                            <h4 class="card-title fw-bold">@user.Name</h4>

                            <p class="card-text text-muted mb-1">
                                <strong>Email:</strong> @user.Email
                            </p>

                            <p class="card-text text-muted mb-1">
                                <strong>Age:</strong> @user.Age
                            </p>

                            <p class="card-text text-muted">
                                <strong>Score:</strong> @user.Score
                            </p>

                        </div>

                        <div class="card-footer bg-transparent border-0 text-end">
                            <a class="btn btn-outline-dark btn-sm">Edit</a>
                            <a class="btn btn-outline-danger btn-sm">Delete</a>
                        </div>

                    </div>
                </div>
            }

        </div>
    }

</div>